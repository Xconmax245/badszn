generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id              String                  @id @default(cuid())
  email           String                  @unique
  firstName       String                  @map("first_name")
  lastName        String                  @map("last_name")
  username        String                  @unique
  phone           String?
  birthday        DateTime?
  avatarUrl       String?                 @map("avatar_url")
  supabaseUid     String?                 @unique @map("supabase_uid")
  totalSpend      Decimal                 @default(0) @map("total_spend") @db.Decimal(12, 2)
  loyaltyTier     LoyaltyTier             @default(BRONZE) @map("loyalty_tier")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  addresses       CustomerAddress[]
  orders          Order[]
  reviews         Review[]
  loyaltyPoints   LoyaltyPoint[]
  referralCode    ReferralCode?
  cartSession     CartSession?
  abandonedCarts  AbandonedCart[]
  returns         Return[]
  notifications   NotificationPreference?
  waitlistEntries WaitlistEntry[]
  savedAddresses  Address[]
  wishlist        Wishlist[]
  eventLogs       EventLog[]

  @@map("customers")
}

model EventLog {
  id        String   @id @default(cuid())
  customerId String?  @map("customer_id")
  type      String   // VISIT, ADD_TO_CART, CHECKOUT
  path      String?
  metadata  Json?
  timestamp DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("event_logs")
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  VIP
}

model CustomerAddress {
  id           String   @id @default(cuid())
  customerId   String   @map("customer_id")
  label        String?
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String
  addressLine1 String   @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  city         String
  state        String
  country      String   @default("Nigeria")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("customer_addresses")
}

model Address {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")

  fullName    String   @map("full_name")
  phone       String

  line1       String
  line2       String?
  city        String
  state       String
  country     String   @default("Nigeria")

  isDefault   Boolean  @default(false) @map("is_default")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  description      String?
  categoryId       String              @map("category_id")
  status           ProductStatus       @default(DRAFT)
  isNew            Boolean             @default(true) @map("is_new")
  isFeatured       Boolean             @default(false) @map("is_featured")
  isBestSeller     Boolean             @default(false) @map("is_best_seller")
  basePrice        Decimal             @map("base_price") @db.Decimal(12, 2)
  compareAtPrice   Decimal?            @map("compare_at_price") @db.Decimal(12, 2)
  metaTitle        String?             @map("meta_title")
  metaDescription  String?             @map("meta_description")
  ogImageUrl       String?             @map("og_image_url")
  material         String?
  fit              String?
  careInstructions String?             @map("care_instructions")
  designNotes      String?             @map("design_notes")
  uniqueness       String?
  modelHeight      String?             @map("model_height")
  modelSize        String?             @map("model_size")
  details          Json?               @map("details")
  shippingCost     Decimal             @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  category         Category            @relation(fields: [categoryId], references: [id])
  variants         ProductVariant[]
  images           ProductImage[]
  collections      CollectionProduct[]
  orderItems       OrderItem[]
  reviews          Review[]
  cartItems        CartItem[]
  lookbookProducts LookbookProduct[]
  wishlist         Wishlist[]

  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductVariant {
  id         String       @id @default(cuid())
  productId  String       @map("product_id")
  size       String
  color      String?
  colorHex   String?      @map("color_hex")
  sku        String       @unique
  stock      Int          @default(0)
  lowStockAt Int          @default(3) @map("low_stock_at")
  price      Decimal?     @db.Decimal(12, 2)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  cartItems   CartItem[]
  returnItems ReturnItem[]

  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────
// COLLECTIONS
// ─────────────────────────────────────────────

model Collection {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  description   String?
  imageUrl      String?             @map("image_url")
  isFeatured    Boolean             @default(false) @map("is_featured")
  featuredOrder Int?                @map("featured_order")
  isActive      Boolean             @default(true) @map("is_active")
  launchDate    DateTime?           @map("launch_date")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  products    CollectionProduct[]
  waitlist    WaitlistEntry[]

  @@map("collections")
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String     @map("collection_id")
  productId    String     @map("product_id")
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@map("collection_products")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique @map("order_number")
  customerId        String?           @map("customer_id")
  addressId         String?           @map("address_id")
  guestEmail        String?           @map("guest_email")
  guestPhone        String?           @map("guest_phone")
  guestFirstName    String?           @map("guest_first_name")
  guestLastName     String?           @map("guest_last_name")
  subtotal          Decimal           @db.Decimal(12, 2)
  shippingCost      Decimal           @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total             Decimal           @db.Decimal(12, 2)
  status            OrderStatus       @default(PENDING)
  paymentStatus     PaymentStatus     @default(UNPAID) @map("payment_status")
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED) @map("fulfillment_status")
  paystackRef       String?           @unique @map("paystack_ref")
  paystackData      Json?             @map("paystack_data")
  shippingAddress   Json?             @map("shipping_address")
  shippingMethod    String?           @map("shipping_method")
  trackingNumber    String?           @map("tracking_number")
  trackingUrl       String?           @map("tracking_url")
  estimatedDelivery DateTime?         @map("estimated_delivery")
  paidAt            DateTime?         @map("paid_at")
  deliveredAt       DateTime?         @map("delivered_at")
  giftMessage       String?           @map("gift_message")
  notes             String?
  discountCodeId    String?           @map("discount_code_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  customer      Customer?        @relation(fields: [customerId], references: [id])
  address       CustomerAddress? @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  discountCode  DiscountCode?    @relation(fields: [discountCodeId], references: [id])
  returns       Return[]
  loyaltyPoints LoyaltyPoint[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String         @map("order_id")
  productId String         @map("product_id")
  variantId String         @map("variant_id")
  name      String
  size      String
  color     String?
  imageUrl  String?        @map("image_url")
  price     Decimal        @db.Decimal(12, 2)
  quantity  Int
  total     Decimal        @db.Decimal(12, 2)
  createdAt DateTime       @default(now()) @map("created_at")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model CartSession {
  id         String     @id @default(cuid())
  customerId String?    @unique @map("customer_id")
  guestId    String?    @unique @map("guest_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  expiresAt  DateTime   @map("expires_at")

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@map("cart_sessions")
}

model CartItem {
  id        String         @id @default(cuid())
  sessionId String         @map("session_id")
  productId String         @map("product_id")
  variantId String         @map("variant_id")
  quantity  Int            @default(1)
  createdAt DateTime       @default(now()) @map("created_at")

  session CartSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([sessionId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String        @id @default(cuid())
  productId  String        @map("product_id")
  customerId String        @map("customer_id")
  rating     Int
  body       String
  isPinned   Boolean       @default(false) @map("is_pinned")
  isVerified Boolean       @default(true) @map("is_verified")
  isApproved Boolean       @default(false) @map("is_approved")
  createdAt  DateTime      @default(now()) @map("created_at")

  product  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id])
  photos   ReviewPhoto[]

  @@map("reviews")
}

model ReviewPhoto {
  id        String @id @default(cuid())
  reviewId  String @map("review_id")
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_photos")
}

// ─────────────────────────────────────────────
// LOYALTY & REFERRALS
// ─────────────────────────────────────────────

model LoyaltyPoint {
  id          String           @id @default(cuid())
  customerId  String           @map("customer_id")
  orderId     String?          @map("order_id")
  points      Int
  type        LoyaltyPointType
  description String
  createdAt   DateTime         @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id])

  @@map("loyalty_points")
}

enum LoyaltyPointType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
}

model ReferralCode {
  id          String   @id @default(cuid())
  customerId  String   @unique @map("customer_id")
  code        String   @unique
  timesUsed   Int      @default(0) @map("times_used")
  totalEarned Decimal  @default(0) @map("total_earned") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("referral_codes")
}

// ─────────────────────────────────────────────
// DISCOUNTS
// ─────────────────────────────────────────────

model DiscountCode {
  id             String       @id @default(cuid())
  code           String       @unique
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @map("min_order_amount") @db.Decimal(12, 2)
  maxUses        Int?         @map("max_uses")
  timesUsed      Int          @default(0) @map("times_used")
  isActive       Boolean      @default(true) @map("is_active")
  startsAt       DateTime?    @map("starts_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  orders Order[]

  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FLAT
  FREE_SHIPPING
}

// ─────────────────────────────────────────────
// ABANDONED CARTS
// ─────────────────────────────────────────────

model AbandonedCart {
  id             String    @id @default(cuid())
  customerId     String?   @map("customer_id")
  email          String
  phone          String?
  cartData       Json      @map("cart_data")
  recoveryToken  String    @unique @map("recovery_token")
  isRecovered    Boolean   @default(false) @map("is_recovered")
  emailSentAt    DateTime? @map("email_sent_at")
  whatsappSentAt DateTime? @map("whatsapp_sent_at")
  recoveredAt    DateTime? @map("recovered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("abandoned_carts")
}

// ─────────────────────────────────────────────
// RETURNS
// ─────────────────────────────────────────────

model Return {
  id           String       @id @default(cuid())
  orderId      String       @map("order_id")
  customerId   String       @map("customer_id")
  reason       ReturnReason
  notes        String?
  status       ReturnStatus @default(REQUESTED)
  refundAmount Decimal?     @map("refund_amount") @db.Decimal(12, 2)
  resolvedAt   DateTime?    @map("resolved_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  order    Order        @relation(fields: [orderId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  items    ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  id        String         @id @default(cuid())
  returnId  String         @map("return_id")
  variantId String         @map("variant_id")
  quantity  Int

  return  Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("return_items")
}

enum ReturnReason {
  WRONG_SIZE
  DAMAGED
  WRONG_ITEM
  CHANGED_MIND
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  REFUNDED
  EXCHANGED
}

// ─────────────────────────────────────────────
// LOOKBOOK
// ─────────────────────────────────────────────

enum LookbookLayoutType {
  SMALL
  MEDIUM
  LARGE
  OVERSIZED
}

model LookbookEntry {
  id          String            @id @default(cuid())
  title         String?
  imageUrl      String            @map("image_url")
  layoutType    LookbookLayoutType @default(MEDIUM) @map("layout_type")
  sequenceGroup String?           @map("sequence_group")
  sortOrder     Int               @default(0) @map("sort_order")
  isPublished   Boolean           @default(false) @map("is_published")
  createdAt     DateTime          @default(now()) @map("created_at")

  products LookbookProduct[]

  @@map("lookbook_entries")
}

model LookbookProduct {
  id        String        @id @default(cuid())
  entryId   String        @map("entry_id")
  productId String        @map("product_id")
  xPosition Float         @map("x_position")
  yPosition Float         @map("y_position")

  entry   LookbookEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@map("lookbook_products")
}

// ─────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────

model Wishlist {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlists")
}

// ─────────────────────────────────────────────
// WAITLIST
// ─────────────────────────────────────────────

model WaitlistEntry {
  id           String      @id @default(cuid())
  email        String
  phone        String?
  collectionId String?     @map("collection_id")
  customerId   String?     @map("customer_id")
  notified     Boolean     @default(false)
  createdAt    DateTime    @default(now()) @map("created_at")

  collection Collection? @relation(fields: [collectionId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])

  @@unique([email, collectionId])
  @@map("waitlist_entries")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model NotificationPreference {
  id             String   @id @default(cuid())
  customerId     String   @unique @map("customer_id")
  emailOrders    Boolean  @default(true) @map("email_orders")
  emailMarketing Boolean  @default(true) @map("email_marketing")
  whatsappOrders Boolean  @default(true) @map("whatsapp_orders")
  whatsappBlasts Boolean  @default(false) @map("whatsapp_blasts")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─────────────────────────────────────────────
// SYSTEM CONFIG
// ─────────────────────────────────────────────

model SiteConfig {
  id               String   @id @default("singleton")
  announcementText String?  @map("announcement_text")
  ethosText        String?  @map("ethos_text") @db.Text
  heroHeadline     String?  @map("hero_headline")
  heroSubtitle     String?  @map("hero_subtitle") @db.Text
  
  // Operational Config
  maintenanceMode    Boolean  @default(false) @map("maintenance_mode")
  lowStockThreshold  Int      @default(5) @map("low_stock_threshold")
  
  // Social Registry
  instagramUrl       String?  @map("instagram_url")
  tiktokUrl          String?  @map("tiktok_url")
  twitterUrl         String?  @map("twitter_url")
  contactEmail       String?  @map("contact_email")

  // Footer Content
  brandMessage       String?  @map("brand_message")
  footerLinks        Json?    @map("footer_links")
  waitlistEnabled    Boolean  @default(true) @map("waitlist_enabled")
  waitlistText       String?  @map("waitlist_text")

  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model VisitorSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique @map("session_id")

  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  country     String?
  city        String?

  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @updatedAt @map("last_seen_at")

  visitCount  Int      @default(1) @map("visit_count")

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("visitor_sessions")
}

model ShopSettings {
  id                   String   @id @default("singleton")
  shopEnabled          Boolean  @default(true)   @map("shop_enabled")
  showSaleBadge        Boolean  @default(true)   @map("show_sale_badge")
  showStockBadge       Boolean  @default(true)   @map("show_stock_badge")
  showNewBadge         Boolean  @default(true)   @map("show_new_badge")
  showSoldOutOverlay   Boolean  @default(true)   @map("show_sold_out_overlay")
  enableFilters        Boolean  @default(true)   @map("enable_filters")
  enableSearch         Boolean  @default(true)   @map("enable_search")
  featuredCategorySlug String?                   @map("featured_category_slug")
  announcementText     String?                   @map("announcement_text")
  updatedAt            DateTime @updatedAt       @map("updated_at")

  @@map("shop_settings")
}

